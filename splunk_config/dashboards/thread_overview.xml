<form version="1.1">
  <label>THREAD Overview</label>
  <description>THREAD distributed tracing — transaction flow, failures, service health, latency, and replay success</description>

  <!-- Panel 1: Transaction Flow (line chart) -->
  <row>
    <panel>
      <title>Transaction Flow (last 1h)</title>
      <chart>
        <search>
          <query>
index=thread_logs earliest=-1h
| eval status=if(traceEvent="REQUEST_ERROR","failed","ok")
| timechart span=1m count by status
          </query>
          <earliest>-1h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleY.text">Events</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.chart.nullValueMode">gaps</option>
        <option name="charting.seriesColors">["#4e9a51","#dc3d2a"]</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>

  <!-- Panel 2: Failed Transactions Table -->
  <row>
    <panel>
      <title>Failed Transactions (last 1h)</title>
      <table>
        <search>
          <query>
index=thread_logs traceEvent=REQUEST_ERROR earliest=-1h
| stats count as failures, first(errorMessage) as reason
    by correlationId, sourceService, targetService
| sort by failures desc
          </query>
          <earliest>-1h</earliest>
          <latest>now</latest>
        </search>
        <option name="wrap">true</option>
        <option name="rowNumbers">false</option>
        <option name="dataOverlayMode">none</option>
        <option name="count">20</option>
        <format type="color" field="failures">
          <colorPalette type="minMidMax" maxColor="#DC4E41" minColor="#FFFFFF"/>
        </format>
      </table>
    </panel>
  </row>

  <!-- Panel 3: Service Health % -->
  <row>
    <panel>
      <title>Service Health % (last 1h)</title>
      <table>
        <search>
          <query>
index=thread_logs earliest=-1h traceEvent IN (REQUEST_END, REQUEST_ERROR)
| eval success=if(traceEvent="REQUEST_END",1,0)
| stats sum(success) as ok, count as total by sourceService
| eval health_pct=round(ok/total*100,1)
| table sourceService, health_pct, ok, total
          </query>
          <earliest>-1h</earliest>
          <latest>now</latest>
        </search>
        <option name="wrap">true</option>
        <format type="color" field="health_pct">
          <colorPalette type="minMidMax" maxColor="#4e9a51" minColor="#DC4E41" midColor="#F8BE34" minValue="0" midValue="80" maxValue="100"/>
        </format>
      </table>
    </panel>
  </row>

  <!-- Panel 4: Average Latency by Service (bar chart) -->
  <row>
    <panel>
      <title>Latency by Service — avg &amp; p95 ms (last 1h)</title>
      <chart>
        <search>
          <query>
index=thread_logs traceEvent=REQUEST_END earliest=-1h
| stats avg(durationMs) as avg_ms, perc95(durationMs) as p95_ms by sourceService
| eval avg_ms=round(avg_ms,0), p95_ms=round(p95_ms,0)
          </query>
          <earliest>-1h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.axisTitleX.text">Service</option>
        <option name="charting.axisTitleY.text">Latency (ms)</option>
        <option name="charting.legend.placement">bottom</option>
      </chart>
    </panel>
  </row>

  <!-- Panel 5: Replay Success Rate (single value) -->
  <row>
    <panel>
      <title>Successful Transactions (last 24h)</title>
      <single>
        <search>
          <query>
index=thread_logs traceEvent IN (REQUEST_START, REQUEST_END) earliest=-24h
| where isnotnull(statusCode) AND statusCode &lt; 400
| stats count by correlationId
| stats count as completed_transactions
          </query>
          <earliest>-24h</earliest>
          <latest>now</latest>
        </search>
        <option name="colorBy">value</option>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0x53A051","0x53A051"]</option>
        <option name="underLabel">completed transactions</option>
        <option name="useColors">1</option>
      </single>
    </panel>
  </row>

</form>
